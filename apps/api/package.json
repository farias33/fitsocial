    "@types/node": "^20.14.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.16.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
