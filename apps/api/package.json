    "@nestjs/platform-fastify": "^10.3.10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/config": "^3.2.3",
    "@prisma/client": "^5.16.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-google-oauth20": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "amqplib": "^0.10.4",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8",
    "reflect-metadata": "^0.2.2",
