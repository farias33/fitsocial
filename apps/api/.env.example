# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fitsocial

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT — troque em produção
JWT_SECRET=dev-secret-local-change-in-prod
JWT_REFRESH_SECRET=dev-refresh-secret-local-change-in-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Storage (MinIO local / S3 em prod)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=fitsocial
STORAGE_PUBLIC_URL=http://localhost:9000/fitsocial

# App
NODE_ENV=development
PORT=4000
